# Production Environment Variables for NinjaWrecks
# Copy this to .env on your Digital Ocean server

APP_NAME="NinjaWrecks"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://www.ninjawrecks.me

# Add your Google Analytics ID (Get from https://analytics.google.com)
GOOGLE_ANALYTICS_ID=

# Your other production settings below
DB_CONNECTION=mysql
# ... rest of your database config
